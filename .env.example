# GCP Configuration
GCP_PROJECT_ID=my-b2b-saas-project    # The GCP project ID for deployment
GCP_REGION=europe-west1               # Default region for resources
GCP_APPLICATION_CREDENTIALS=./keys/service-account-key.json # Path to SA key

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092 # Kafka broker address
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081 # Schema Registry endpoint
KAFKA_TOPIC_CAMPAIGNS=campaigns       # Core business topic

# Redis Cache Configuration
REDIS_HOST=localhost                  # Redis server address
REDIS_PORT=6379                       # Redis server port
REDIS_PASSWORD=mypassword             # Redis authentication (leave empty if not required)

# Monitoring & Logging
PROMETHEUS_ENDPOINT=http://localhost:9090 # Prometheus server URL
ES_USER=logstash_internal             # Elasticsearch internal user for Logstash
ES_PASSWORD=changeme                  # Elasticsearch password

# Application Runtime
SPRING_PROFILES_ACTIVE=dev            # Active Spring Boot profile (dev, staging, prod)
JAVA_OPTS="-Xmx2g -Xms2g"             # JVM memory settings for local dev
